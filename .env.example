# SparkCore – Environment Variables
# Copy this file to .env (which is gitignored) and fill in your values.
# docker-compose.yml reads these variables at runtime.

POSTGRES_USER=sparkcore_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=sparkcore_db

PGADMIN_DEFAULT_EMAIL=admin@sparkcore.com
PGADMIN_DEFAULT_PASSWORD=change_me_in_production
